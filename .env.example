# ═══════════════════════════════════════════════════════════════════════════
# StadiumOS AI — environment variables (copy to .env, never commit .env)
# ═══════════════════════════════════════════════════════════════════════════

# Gemini (Google Generative Language API) — server-side only.
GEMINI_API_KEY=your-gemini-api-key

# Firebase Admin service account — the ONLY credential that can write Firestore.
# Paste the full service-account JSON on ONE line (escape inner quotes), from:
#   Firebase Console → Project settings → Service accounts → Generate new private key
# On Vercel, add this as an Environment Variable (Settings → Environment Variables).
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Alternative for LOCAL dev: path to the downloaded key file instead of the JSON above.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
